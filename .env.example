# HTTP bind host, example: 0.0.0.0 for all interfaces
SERVER_HOST=0.0.0.0
# HTTP bind port, example: 8080
SERVER_PORT=8080
# Max duration for reading incoming request bodies
SERVER_READ_TIMEOUT=10s
# Max duration for writing responses
SERVER_WRITE_TIMEOUT=10s
# Graceful shutdown timeout before force close
SERVER_SHUTDOWN_TIMEOUT=10s
# Generic rate limit requests per window (reserved config)
SERVER_RATE_LIMIT_REQUESTS=120
# Generic rate limit window duration (reserved config)
SERVER_RATE_LIMIT_WINDOW=1m

# Comma-separated CORS origins, use * for demo
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL hostname or container service name
DB_HOST=localhost
# PostgreSQL port exposed on host
DB_PORT=55432
# PostgreSQL user
DB_USER=echo
# PostgreSQL password
DB_PASSWORD=echo
# PostgreSQL database name
DB_NAME=echo
# PostgreSQL SSL mode, disable for local dev
DB_SSL_MODE=disable

# Redis address host:port
REDIS_ADDR=localhost:6379
# Redis password, empty for local default
REDIS_PASSWORD=
# Redis logical DB index
REDIS_DB=0

# JWT signing secret used for access tokens
JWT_SECRET=change-me
# JWT token lifetime duration
JWT_TTL=24h

# Number of reports required to auto-hide a post
MODERATION_AUTO_HIDE_THRESHOLD=3
